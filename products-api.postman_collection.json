              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{user_id}}\",\n  \"shippingAddress\": {\n    \"street\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"province\": \"NY\",\n    \"postalCode\": \"10001\",\n    \"country\": \"US\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/payments/intent",
          "host": ["{{base_url}}"],
          "path": ["payments", "intent"]
        },
        "description": "Create a Stripe PaymentIntent for on-site card payment. Currency is auto-detected from shipping country (CA→CAD, US→USD) or client IP. Cart must exist for this user. Returns clientSecret for the frontend to complete payment with Stripe Elements."
      },
      "response": [
        {
          "name": "Payment Intent Created",
          "status": "Created",
          "code": 201,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"statusCode\": 201,\n  \"success\": true,\n  \"message\": \"Payment intent created successfully\",\n  \"data\": {\n    \"clientSecret\": \"pi_3Rabc123_secret_xyz456\",\n    \"paymentId\": \"507f1f77bcf86cd799439011\"\n  }\n}"
        }
      ]
    },
